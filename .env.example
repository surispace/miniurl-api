# MyURL Microservices Environment Configuration
# Copy this file to .env and update the values

# ===========================================
# INFRASTRUCTURE CONFIGURATION
# ===========================================
EUREKA_SERVER_PORT=8761
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================================
# IDENTITY SERVICE CONFIGURATION
# ===========================================
IDENTITY_SERVICE_PORT=8081
IDENTITY_DB_URL=jdbc:mysql://localhost:33061/identity_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
IDENTITY_DB_USERNAME=root
IDENTITY_DB_PASSWORD=root

# RS256 Key Pair (For Identity Service)
# Generate using: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
IDENTITY_JWT_PRIVATE_KEY_PATH=/etc/miniurl/keys/private.pem
IDENTITY_JWT_PUBLIC_KEY_PATH=/etc/miniurl/keys/public.pem

# ===========================================
# URL SERVICE CONFIGURATION
# ===========================================
URL_SERVICE_PORT=8082
URL_DB_URL=jdbc:mysql://localhost:33062/url_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
URL_DB_USERNAME=root
URL_DB_PASSWORD=root

# ===========================================
# REDIRECT SERVICE CONFIGURATION (Reactive)
# ===========================================
REDIRECT_SERVICE_PORT=8083
REDIRECT_REDIS_HOST=localhost
REDIRECT_REDIS_PORT=6379

# ===========================================
# FEATURE SERVICE CONFIGURATION
# ===========================================
FEATURE_SERVICE_PORT=8084
FEATURE_DB_URL=jdbc:mysql://localhost:33063/feature_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
FEATURE_DB_USERNAME=root
FEATURE_DB_PASSWORD=root

# ===========================================
# API GATEWAY CONFIGURATION
# ===========================================
GATEWAY_PORT=8080
GATEWAY_EUREKA_URL=http://localhost:8761/eureka/
GATEWAY_REDIS_HOST=localhost
GATEWAY_REDIS_PORT=6379

# ===========================================
# SHARED CONFIGURATION
# ===========================================
APP_BASE_URL=https://api.example.com
APP_UI_BASE_URL=https://example.com
APP_CORS_ALLOWED_ORIGINS=https://ui.example.com
